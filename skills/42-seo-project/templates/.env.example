# SEO Project Configuration
# Generated by /seo-project init
# Location: 42-reports/<domain>/.env

# === Project ===
SITE_URL=
DOMAIN=
BUSINESS_TYPE=
LANGUAGE=

# === Screaming Frog ===
SF_AVAILABLE=                        # auto-detected (true/false)
SF_EXPORT_DIR=                       # default: 42-reports/<domain>/exports
# SF_CONFIG=                         # optional: path to custom .seospider profile

# === Data APIs (optional — skills degrade gracefully without these) ===
# DataForSEO — ~$0.002/query — https://dataforseo.com
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google Gemini — embeddings voor keyword-mapper, passage-analyzer, near-duplicates
# Account: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Google Search Console — https://console.cloud.google.com
GOOGLE_SERVICE_ACCOUNT_JSON=
