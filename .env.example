# 42-SEO-Skills Environment Variables
# Kopieer dit bestand naar .env en vul de waarden in
# cp .env.example .env

# ============================================================================
# GEMINI API (voor Screaming Frog embeddings + AI-analyse)
# ============================================================================
# Krijg gratis key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ============================================================================
# DATAFORSEO (voor keyword research, SERP data, share of voice)
# ============================================================================
# Account: https://dataforseo.com
# Pricing: pay-as-you-go, ~$0.01-0.03 per request
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ============================================================================
# FIRECRAWL (voor deep content extraction, brand mentions)
# ============================================================================
# Account: https://firecrawl.dev
# Note: als je Firecrawl MCP server al werkt via Claude Code, is deze key
# niet nodig — de MCP server regelt auth automatisch
FIRECRAWL_API_KEY=

# ============================================================================
# GOOGLE SEARCH CONSOLE (voor historische rankings data)
# ============================================================================
# Optie 1: Service Account JSON path
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optie 2: OAuth credentials
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# ============================================================================
# GOOGLE ANALYTICS 4 (voor conversie/sessie data)
# ============================================================================
GA4_PROPERTY_ID=
# Gebruikt GOOGLE_SERVICE_ACCOUNT_JSON

# ============================================================================
# SCREAMING FROG (optioneel — als je CLI in PATH wilt)
# ============================================================================
# Voeg dit toe aan je shell profile (~/.zshrc of ~/.bashrc):
# export PATH="/Applications/Screaming Frog SEO Spider.app/Contents/MacOS:$PATH"
